## Section 6 — Database Schema

```sql
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Core Tables
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

-- Users
CREATE TABLE users (
  id                    UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  email                 VARCHAR(255) UNIQUE,
  phone                 VARCHAR(20) UNIQUE,
  password_hash         VARCHAR(255),
  primary_role          VARCHAR(50) NOT NULL,
  -- FOUNDER/INVESTOR/ACCELERATOR/OPERATOR/ANGEL/FRANCHISE
  full_name_ar          VARCHAR(255),
  full_name_en          VARCHAR(255),
  username              VARCHAR(50) UNIQUE,
  profile_photo_url     TEXT,
  cover_photo_url       TEXT,
  bio_ar                TEXT,
  bio_en                TEXT,
  headline              VARCHAR(200),
  country               VARCHAR(2),
  city                  VARCHAR(100),
  language_pref         VARCHAR(5) DEFAULT 'ar',
  email_verified        BOOLEAN DEFAULT FALSE,
  phone_verified        BOOLEAN DEFAULT FALSE,
  identity_verified     BOOLEAN DEFAULT FALSE,
  verification_level    SMALLINT DEFAULT 0,
  trust_score           SMALLINT DEFAULT 0,
  activity_score        SMALLINT DEFAULT 0,
  subscription_plan     VARCHAR(50) DEFAULT 'FREE',
  subscription_expires  TIMESTAMPTZ,
  is_active             BOOLEAN DEFAULT TRUE,
  is_suspended          BOOLEAN DEFAULT FALSE,
  suspension_reason     TEXT,
  last_active_at        TIMESTAMPTZ,
  created_at            TIMESTAMPTZ DEFAULT NOW(),
  updated_at            TIMESTAMPTZ DEFAULT NOW()
);

CREATE INDEX idx_users_role ON users(primary_role);
CREATE INDEX idx_users_country ON users(country);
CREATE INDEX idx_users_active ON users(is_active, last_active_at);

-- Companies
CREATE TABLE companies (
  id                    UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  name                  VARCHAR(255) NOT NULL,
  slug                  VARCHAR(100) UNIQUE NOT NULL,
  logo_url              TEXT,
  cover_url             TEXT,
  tagline               VARCHAR(200),
  description           TEXT,
  website               VARCHAR(255),
  founded_year          SMALLINT,
  country               VARCHAR(2),
  city                  VARCHAR(100),
  company_type          VARCHAR(50) NOT NULL,
  -- STARTUP/VC_FUND/ACCELERATOR/FRANCHISE_BRAND...
  stage                 VARCHAR(50),
  -- IDEA/PRE_SEED/SEED/SERIES_A/SERIES_B/GROWTH
  primary_sector        VARCHAR(50),
  sectors               TEXT[],
  business_model        VARCHAR(20),
  team_size             SMALLINT,
  is_verified           BOOLEAN DEFAULT FALSE,
  verification_date     TIMESTAMPTZ,
  created_by            UUID REFERENCES users(id),
  created_at            TIMESTAMPTZ DEFAULT NOW(),
  updated_at            TIMESTAMPTZ DEFAULT NOW()
);

-- Accelerators
CREATE TABLE accelerator_profiles (
  id                    UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  company_id            UUID UNIQUE REFERENCES companies(id),
  total_cohorts         SMALLINT DEFAULT 0,
  total_startups        INTEGER DEFAULT 0,
  total_funding_raised  BIGINT DEFAULT 0,
  acceptance_rate       DECIMAL(5,2),
  program_duration_weeks SMALLINT,
  equity_taken          BOOLEAN DEFAULT FALSE,
  equity_percentage     DECIMAL(5,2),
  investment_amount     INTEGER,
  is_verified           BOOLEAN DEFAULT FALSE,
  created_at            TIMESTAMPTZ DEFAULT NOW()
);

-- Cohorts
CREATE TABLE cohorts (
  id                    UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  accelerator_id        UUID REFERENCES accelerator_profiles(id),
  cohort_number         SMALLINT,
  name                  VARCHAR(100),
  status                VARCHAR(50) DEFAULT 'ACTIVE',
  -- ACTIVE/DEMO_DAY/GRADUATED/ARCHIVED
  start_date            DATE,
  end_date              DATE,
  demo_day_date         DATE,
  target_size           SMALLINT,
  created_at            TIMESTAMPTZ DEFAULT NOW()
);

-- Cohort Startups (Junction)
CREATE TABLE cohort_startups (
  id                    UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  cohort_id             UUID REFERENCES cohorts(id),
  company_id            UUID REFERENCES companies(id),
  status                VARCHAR(50) DEFAULT 'IN_PROGRAM',
  -- IN_PROGRAM/GRADUATED/RAISING/FUNDED/DROPPED
  joined_at             DATE,
  graduated_at          DATE,
  investment_readiness_score SMALLINT,
  score_team            SMALLINT,
  score_product         SMALLINT,
  score_revenue         SMALLINT,
  score_readiness       SMALLINT,
  score_notes           TEXT,
  scored_by             UUID REFERENCES users(id),
  scored_at             TIMESTAMPTZ,
  accelerator_backed    BOOLEAN DEFAULT FALSE,
  accelerator_note      TEXT,
  UNIQUE(cohort_id, company_id)
);

-- Deal Rooms
CREATE TABLE deal_rooms (
  id                    UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  company_id            UUID REFERENCES companies(id),
  owner_id              UUID REFERENCES users(id),
  name                  VARCHAR(255),
  type                  VARCHAR(50),
  -- FUNDRAISING/DEMO_DAY/PARTNERSHIP
  privacy               VARCHAR(50) DEFAULT 'PRIVATE',
  -- PUBLIC/PRIVATE/INVITE_ONLY/NDA_GATED
  raising_amount        BIGINT,
  raising_currency      VARCHAR(3) DEFAULT 'USD',
  amount_committed      BIGINT DEFAULT 0,
  instrument            VARCHAR(50),
  pre_money_valuation   BIGINT,
  closing_date          DATE,
  status                VARCHAR(50) DEFAULT 'ACTIVE',
  -- ACTIVE/PAUSED/CLOSED/FUNDED
  unique_link_token     VARCHAR(100) UNIQUE,
  views_count           INTEGER DEFAULT 0,
  unique_visitors       INTEGER DEFAULT 0,
  created_at            TIMESTAMPTZ DEFAULT NOW(),
  updated_at            TIMESTAMPTZ DEFAULT NOW()
);

-- Pitch Decks
CREATE TABLE pitch_decks (
  id                    UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  deal_room_id          UUID REFERENCES deal_rooms(id),
  original_filename     VARCHAR(255),
  file_url              TEXT,
  slides_count          SMALLINT,
  processing_status     VARCHAR(50) DEFAULT 'PROCESSING',
  ai_analysis           JSONB,
  ai_score              SMALLINT,
  is_active             BOOLEAN DEFAULT TRUE,
  uploaded_by           UUID REFERENCES users(id),
  created_at            TIMESTAMPTZ DEFAULT NOW()
);

-- Deal Room Visits
CREATE TABLE deal_room_visits (
  id                    UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  deal_room_id          UUID REFERENCES deal_rooms(id),
  visitor_id            UUID REFERENCES users(id),
  entered_at            TIMESTAMPTZ DEFAULT NOW(),
  exited_at             TIMESTAMPTZ,
  duration_seconds      INTEGER,
  slides_viewed         SMALLINT[],
  time_per_slide        JSONB,
  -- {"1": 45, "2": 30...}
  exit_slide            SMALLINT,
  device_type           VARCHAR(20),
  platform              VARCHAR(20)
);

CREATE INDEX idx_visits_room ON deal_room_visits(deal_room_id);
CREATE INDEX idx_visits_visitor ON deal_room_visits(visitor_id);

-- Interest Signals
CREATE TABLE interest_signals (
  id                    UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  deal_room_id          UUID REFERENCES deal_rooms(id),
  user_id               UUID REFERENCES users(id),
  level                 VARCHAR(50),
  -- WATCHING/INTERESTED/READY_TO_INVEST
  private_note          TEXT,
  is_visible_to_owner   BOOLEAN DEFAULT FALSE,
  created_at            TIMESTAMPTZ DEFAULT NOW(),
  updated_at            TIMESTAMPTZ DEFAULT NOW(),
  UNIQUE(deal_room_id, user_id)
);

-- Equity Roles
CREATE TABLE equity_roles (
  id                    UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  company_id            UUID REFERENCES companies(id),
  posted_by             UUID REFERENCES users(id),
  title                 VARCHAR(200),
  role_type             VARCHAR(50),
  domain                VARCHAR(50),
  description           TEXT,
  why_exciting          TEXT,
  equity_min            DECIMAL(5,2),
  equity_max            DECIMAL(5,2),
  cash_component        BOOLEAN DEFAULT FALSE,
  cash_amount           INTEGER,
  time_commitment       VARCHAR(50),
  location_type         VARCHAR(50),
  location_city         VARCHAR(100),
  min_years_experience  SMALLINT,
  required_skills       TEXT[],
  vesting_months        SMALLINT DEFAULT 48,
  cliff_months          SMALLINT DEFAULT 12,
  status                VARCHAR(50) DEFAULT 'OPEN',
  views_count           INTEGER DEFAULT 0,
  applications_count    INTEGER DEFAULT 0,
  created_at            TIMESTAMPTZ DEFAULT NOW(),
  expires_at            TIMESTAMPTZ
);

-- Equity Applications
CREATE TABLE equity_applications (
  id                    UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  role_id               UUID REFERENCES equity_roles(id),
  applicant_id          UUID REFERENCES users(id),
  status                VARCHAR(50) DEFAULT 'SUBMITTED',
  cover_note            VARCHAR(500),
  why_this_company      TEXT,
  what_i_bring          TEXT,
  equity_counter        DECIMAL(5,2),
  ai_compatibility      SMALLINT,
  ai_compatibility_details JSONB,
  founder_rating        SMALLINT,
  founder_notes         TEXT,
  final_equity          DECIMAL(5,2),
  agreement_signed      BOOLEAN DEFAULT FALSE,
  created_at            TIMESTAMPTZ DEFAULT NOW(),
  updated_at            TIMESTAMPTZ DEFAULT NOW(),
  UNIQUE(role_id, applicant_id)
);

-- Posts
CREATE TABLE posts (
  id                    UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  author_id             UUID REFERENCES users(id),
  company_id            UUID REFERENCES companies(id),
  room_id               UUID,
  type                  VARCHAR(50),
  content               TEXT,
  media_urls            TEXT[],
  visibility            VARCHAR(50) DEFAULT 'PUBLIC',
  is_verified_claim     BOOLEAN DEFAULT FALSE,
  verification_source   VARCHAR(100),
  linked_deal_id        UUID,
  reactions_count       JSONB DEFAULT '{}',
  comments_count        INTEGER DEFAULT 0,
  shares_count          INTEGER DEFAULT 0,
  saves_count           INTEGER DEFAULT 0,
  views_count           INTEGER DEFAULT 0,
  relevance_scores      JSONB DEFAULT '{}',
  is_active             BOOLEAN DEFAULT TRUE,
  edited_at             TIMESTAMPTZ,
  created_at            TIMESTAMPTZ DEFAULT NOW()
);

CREATE INDEX idx_posts_author ON posts(author_id, created_at DESC);
CREATE INDEX idx_posts_type ON posts(type);
CREATE INDEX idx_posts_visibility ON posts(visibility);

-- Connections
CREATE TABLE connections (
  id                    UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  user_a_id             UUID REFERENCES users(id),
  user_b_id             UUID REFERENCES users(id),
  type                  VARCHAR(20) DEFAULT 'CONNECTED',
  status                VARCHAR(20) DEFAULT 'PENDING',
  strength_score        SMALLINT DEFAULT 0,
  context               VARCHAR(50),
  introducer_id         UUID REFERENCES users(id),
  messages_count        INTEGER DEFAULT 0,
  deals_together        INTEGER DEFAULT 0,
  last_interacted_at    TIMESTAMPTZ,
  created_at            TIMESTAMPTZ DEFAULT NOW(),
  UNIQUE(user_a_id, user_b_id),
  CHECK(user_a_id < user_b_id)
);

-- Notifications
CREATE TABLE notifications (
  id                    UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  user_id               UUID REFERENCES users(id),
  type                  VARCHAR(100) NOT NULL,
  title_ar              VARCHAR(255),
  title_en              VARCHAR(255),
  body_ar               TEXT,
  body_en               TEXT,
  deep_link             VARCHAR(500),
  priority              VARCHAR(10) DEFAULT 'MEDIUM',
  is_read               BOOLEAN DEFAULT FALSE,
  is_pushed             BOOLEAN DEFAULT FALSE,
  related_entity_type   VARCHAR(50),
  related_entity_id     UUID,
  expires_at            TIMESTAMPTZ,
  created_at            TIMESTAMPTZ DEFAULT NOW()
);

CREATE INDEX idx_notif_user ON notifications(user_id, is_read, created_at DESC);

-- AI Meeting Notes
CREATE TABLE meeting_notes (
  id                    UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  owner_id              UUID REFERENCES users(id),
  contact_id            UUID REFERENCES users(id),
  deal_id               UUID,
  audio_duration_sec    INTEGER,
  transcript            TEXT,
  summary               TEXT,
  action_items          JSONB,
  -- [{assignee, task, due_date, status}]
  topics                TEXT[],
  sentiment             VARCHAR(20),
  deal_stage_suggested  VARCHAR(50),
  model_used            VARCHAR(50),
  tokens_used           INTEGER,
  created_at            TIMESTAMPTZ DEFAULT NOW()
);
```

