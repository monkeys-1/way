-- Auto-update updated_at
CREATE OR REPLACE FUNCTION update_updated_at()
RETURNS TRIGGER AS $$
BEGIN
  NEW.updated_at = NOW();
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

-- Apply to all tables with updated_at
CREATE TRIGGER trg_users_updated
  BEFORE UPDATE ON users
  FOR EACH ROW EXECUTE FUNCTION update_updated_at();

CREATE TRIGGER trg_companies_updated
  BEFORE UPDATE ON companies
  FOR EACH ROW EXECUTE FUNCTION update_updated_at();

CREATE TRIGGER trg_deal_rooms_updated
  BEFORE UPDATE ON deal_rooms
  FOR EACH ROW EXECUTE FUNCTION update_updated_at();

-- Auto-calculate cohort_startup score badge
CREATE OR REPLACE FUNCTION update_accelerator_backed()
RETURNS TRIGGER AS $$
BEGIN
  IF NEW.total_score >= 60 AND
     NEW.status = 'GRADUATED' AND
     NEW.accelerator_backed = FALSE THEN
    NEW.accelerator_backed = TRUE;
    NEW.backed_at = NOW();
  END IF;
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_cohort_startup_badge
  BEFORE INSERT OR UPDATE ON cohort_startups
  FOR EACH ROW EXECUTE FUNCTION update_accelerator_backed();

-- Auto-update post reaction counts
CREATE OR REPLACE FUNCTION update_post_reaction_count()
RETURNS TRIGGER AS $$
BEGIN
  IF TG_OP = 'INSERT' THEN
    UPDATE posts
    SET reactions_count = jsonb_set(
      reactions_count,
      ARRAY[NEW.reaction_type],
      (COALESCE((reactions_count->>NEW.reaction_type)::int, 0) + 1)::text::jsonb
    )
    WHERE id = NEW.post_id;
  ELSIF TG_OP = 'DELETE' THEN
    UPDATE posts
    SET reactions_count = jsonb_set(
      reactions_count,
      ARRAY[OLD.reaction_type],
      GREATEST(0, COALESCE((reactions_count->>OLD.reaction_type)::int, 0) - 1)::text::jsonb
    )
    WHERE id = OLD.post_id;
  END IF;
  RETURN NULL;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_post_reactions
  AFTER INSERT OR DELETE ON post_reactions
  FOR EACH ROW EXECUTE FUNCTION update_post_reaction_count();
