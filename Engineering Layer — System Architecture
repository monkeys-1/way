                        CHECK (score_team BETWEEN 0 AND 25),
  score_product         SMALLINT DEFAULT 0
                        CHECK (score_product BETWEEN 0 AND 25),
  score_revenue         SMALLINT DEFAULT 0
                        CHECK (score_revenue BETWEEN 0 AND 25),
  score_readiness       SMALLINT DEFAULT 0
                        CHECK (score_readiness BETWEEN 0 AND 25),

  -- Auto-calculated
  total_score           SMALLINT GENERATED ALWAYS AS (
    score_team + score_product +
    score_revenue + score_readiness
  ) STORED,

  score_notes           TEXT,
  accelerator_note      TEXT,

  recommend_status      VARCHAR(20),
  -- READY/SOON/NOT_YET

  scored_by             UUID REFERENCES users(id),
  scored_at             TIMESTAMPTZ,

  -- Verified Badge
  accelerator_backed    BOOLEAN DEFAULT FALSE,
  backed_at             TIMESTAMPTZ,

  created_at            TIMESTAMPTZ DEFAULT NOW(),
  updated_at            TIMESTAMPTZ DEFAULT NOW(),
  UNIQUE(cohort_id, company_id)
);

