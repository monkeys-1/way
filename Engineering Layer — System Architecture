class MatchResult(BaseModel):
    company_id: str
    match_score: int  # 0-100
    match_reasons: list[str]
    potential_concerns: list[str]
    recommended_approach: str

async def generate_embedding(text: str) -> list[float]:
    client = AsyncOpenAI()
    response = await client.embeddings.create(
        input=text,
        model="text-embedding-3-large"
    )
    return response.data[0].embedding

async def match_investor_to_startups(
    investor_id: str,
    investor_profile: dict,
    limit: int = 20
) -> list[MatchResult]:
    """
    Smart matching pipeline:
    1. Build investor profile text
    2. Generate embedding
    3. Query Pinecone for similar startups
    4. Re-rank with GPT-4o
    5. Filter already-seen deals
    6. Return ranked matches
    """

    # Step 1: Build rich investor profile text
    investor_text = f"""
    Investment Thesis: {investor_profile['thesis']}
    Focus Sectors: {', '.join(investor_profile['sectors'])}
    Target Stages: {', '.join(investor_profile['stages'])}
    Check Size: ${investor_profile['check_min']}K-${investor_profile['check_max']}K
    Portfolio: {investor_profile['portfolio_description']}
    Recent investments: {investor_profile['recent_deals']}
    What I look for: {investor_profile['criteria']}
    """

    # Step 2: Generate embedding
    investor_embedding = await generate_embedding(investor_text)

    # Step 3: Query Pinecone
    results = index.query(
        vector=investor_embedding,
        top_k=50,
        namespace="startups",
        filter={
            "stage": {"$in": investor_profile['stages']},
            "sector": {"$in": investor_profile['sectors']},
            "country": {"$in": investor_profile['geographies']},
            "is_raising": True,
            "accelerator_backed": True
        },
        include_metadata=True
    )

    # Step 4: Re-rank top 20 with GPT-4o
    candidates = [
        {
            "company_id": r.id,
            "metadata": r.metadata,
            "vector_score": r.score
        }
        for r in results.matches[:20]
    ]

    rerank_prompt = f"""
    Investor Profile:
    {investor_text}

    Candidate Startups:
    {candidates}

    Re-rank these startups for this specific investor.
    Consider: thesis fit, stage, sector, traction, team quality.
    Return JSON array of MatchResult objects, top 10 only.
    Be specific about WHY each is a good match.
    """

    llm = ChatOpenAI(model="gpt-4o", temperature=0)
    response = await llm.ainvoke(rerank_prompt)

    return parse_match_results(response.content)

