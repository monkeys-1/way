async def analyze_pitch_deck(
    deck_id: str,
    file_url: str
) -> DeckAnalysis:
    """
    Full pipeline:
    1. Download PDF
    2. Convert to images
    3. GPT-4o Vision analysis per slide
    4. Aggregate and score
    5. MENA-specific feedback
    6. Store results
    """

    # Step 1: Convert PDF to images
    pdf_document = fitz.open(file_url)
    slide_images = []

    for page_num in range(len(pdf_document)):
        page = pdf_document[page_num]
        mat = fitz.Matrix(2, 2)  # 2x zoom for quality
        clip = page.get_pixmap(matrix=mat)
        img_bytes = clip.tobytes("png")
        b64 = base64.b64encode(img_bytes).decode()
        slide_images.append({
            "slide_num": page_num + 1,
            "image_b64": b64
        })

    # Step 2: Analyze each slide with GPT-4o Vision
    llm = ChatOpenAI(model="gpt-4o", temperature=0)
    slide_analyses = []

    for slide in slide_images:
        prompt = ChatPromptTemplate.from_messages([
            ("system", SLIDE_ANALYSIS_SYSTEM_PROMPT),
            ("human", [
                {
                    "type": "image_url",
                    "image_url": {
                        "url": f"data:image/png;base64,{slide['image_b64']}"
                    }
                },
                {
                    "type": "text",
                    "text": f"""
                    Analyze slide {slide['slide_num']}.
                    Context: This is a MENA startup pitch deck.
                    Investors are from Gulf region (KSA, UAE).
                    Return JSON matching the SlideAnalysis schema.
                    """
                }
            ])
        ])

        parser = JsonOutputParser(pydantic_object=SlideAnalysis)
        chain = prompt | llm | parser
        analysis = await chain.ainvoke({})
        slide_analyses.append(analysis)

    # Step 3: Aggregate analysis
    aggregation_prompt = ChatPromptTemplate.from_messages([
        ("system", DECK_AGGREGATION_SYSTEM_PROMPT),
        ("human", f"""
        Slide analyses:
        {[a.dict() for a in slide_analyses]}

        Generate overall deck analysis for MENA investors.
        Focus on: Saudi Arabia, UAE, Egypt markets.
        Consider: Cultural context, regulatory environment,
                  MENA VC expectations.
        Return JSON matching DeckAnalysis schema.
        """)
    ])

    parser = JsonOutputParser(pydantic_object=DeckAnalysis)
    chain = aggregation_prompt | llm | parser
    deck_analysis = await chain.ainvoke({})

    # Step 4: Store in database
    await store_deck_analysis(deck_id, deck_analysis)

    return deck_analysis


