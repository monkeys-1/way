```python
# ai_service/execution_score.py

class ExecutionScoreComponents(BaseModel):
    promise_delivery_rate: float     # 0-1
    milestone_hit_rate: float        # 0-1
    revenue_growth_consistency: float # 0-1
    team_retention_rate: float        # 0-1
    investor_communication_score: float # 0-1
    burn_efficiency_score: float      # 0-1

    # Weights
    WEIGHTS = {
        "promise_delivery": 0.25,
        "milestone_hit": 0.20,
        "revenue_growth": 0.20,
        "team_retention": 0.15,
        "investor_communication": 0.10,
        "burn_efficiency": 0.10
    }

async def calculate_execution_score(
    founder_id: str,
    company_id: str
) -> dict:
    """
    Calculates the Execution Score (0-100)
    Based on verified behavioral data only.
    NOT on self-reported claims.
    """

    # 1. Promise vs Delivery
    milestones = await get_all_milestones(company_id)
    completed_on_time = sum(
        1 for m in milestones
        if m.completed_at and m.completed_at <= m.due_date
    )
    promise_delivery = (
        completed_on_time / len(milestones)
        if milestones else 0.5  # neutral if no data
    )

    # 2. Revenue Growth Consistency
    kpi_history = await get_kpi_history(company_id, months=6)
    if len(kpi_history) >= 3:
        growth_rates = [
            (kpi_history[i].mrr - kpi_history[i-1].mrr)
            / kpi_history[i-1].mrr
            if kpi_history[i-1].mrr > 0 else 0
            for i in range(1, len(kpi_history))
        ]
        # Consistency = low variance in growth
        import statistics
        variance = statistics.variance(growth_rates)
        revenue_growth = max(0, 1 - variance)
    else:
        revenue_growth = 0.5

    # 3. Team Retention
    team_history = await get_team_history(company_id, months=12)
    if team_history:
        avg_tenure = sum(
            m.months_active for m in team_history
        ) / len(team_history)
        team_retention = min(1.0, avg_tenure / 12)
    else:
        team_retention = 0.5

    # 4. Investor Communication Score
    update_frequency = await get_update_frequency(company_id)
    # Expected: monthly updates
    communication = min(
        1.0,
        update_frequency.updates_per_month / 1.0
    )

    # 5. KPI Update Timeliness
    kpi_updates = await get_kpi_update_timeliness(company_id)
    timeliness = kpi_updates.on_time_rate

    # Calculate weighted score
    raw_score = (
        promise_delivery * 0.25 +
        (completed_on_time / max(len(milestones), 1)) * 0.20 +
        revenue_growth * 0.20 +
        team_retention * 0.15 +
        communication * 0.10 +
        timeliness * 0.10
    )

    final_score = round(raw_score * 100)

    # Generate explanation
    explanation = await generate_score_explanation(
        founder_id=founder_id,
        score=final_score,
        components={
            "promise_delivery": round(promise_delivery * 100),
            "revenue_growth": round(revenue_growth * 100),
            "team_retention": round(team_retention * 100),
            "communication": round(communication * 100),
        }
    )

    return {
        "score": final_score,
        "components": {
            "promise_delivery": round(promise_delivery * 100),
            "revenue_growth": round(revenue_growth * 100),
            "team_retention": round(team_retention * 100),
            "communication": round(communication * 100),
        },
        "explanation_ar": explanation['ar'],
        "explanation_en": explanation['en'],
        "data_points_count": len(milestones) + len(kpi_history),
        "calculated_at": datetime.now().isoformat()
    }
