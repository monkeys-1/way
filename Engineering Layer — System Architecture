async def process_meeting_note(
    audio_file_path: str,
    owner_id: str,
    contact_info: dict,
    deal_context: dict | None = None
) -> MeetingIntelligence:
    """
    Pipeline:
    1. Whisper transcription (Arabic + English)
    2. GPT-4o intelligence extraction
    3. Deal context integration
    4. Action items with assignments
    5. Delete audio after processing
    """

    # Step 1: Transcribe with Whisper
    client = openai.AsyncOpenAI()

    with open(audio_file_path, "rb") as audio_file:
        transcription = await client.audio.transcriptions.create(
            model="whisper-1",
            file=audio_file,
            language=None,  # Auto-detect AR/EN
            response_format="verbose_json",
            timestamp_granularities=["segment"]
        )

    transcript_text = transcription.text

    # Step 2: Extract intelligence
    context = f"""
    Meeting between:
    - Investor: {owner_id}
    - Contact: {contact_info.get('name')} at {contact_info.get('company')}

    Deal Context: {deal_context or 'No prior context'}

    Meeting Transcript:
    {transcript_text}
    """

    prompt = ChatPromptTemplate.from_messages([
        ("system", MEETING_INTELLIGENCE_PROMPT),
        ("human", context)
    ])

    llm = ChatOpenAI(model="gpt-4o", temperature=0)
    parser = JsonOutputParser(pydantic_object=MeetingIntelligence)
    chain = prompt | llm | parser
    intelligence = await chain.ainvoke({})

    # Step 3: Delete audio for privacy
    import os
    os.remove(audio_file_path)

    return intelligence


